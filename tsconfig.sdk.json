{
  "compilerOptions": {
    "rootDir": "./sentinel-sdk",
    "outDir": "./dist",
    "module": "ESNext",
    "moduleResolution": "nodenext",
    "target": "ES2020",
    "declaration": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": ["sentinel-sdk/**/*"]
}
